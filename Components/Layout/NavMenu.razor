        @if (Mostrar("/aalinea"))
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="aalinea">
                    <span class="bi bi-link-45deg-nav-menu" aria-hidden="true"></span> Área Ap - Línea
                </NavLink>
            </div>
        }

        @if (Mostrar("/aclinea"))
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="aclinea">
                    <span class="bi bi-link-45deg-nav-menu" aria-hidden="true"></span> Área Conoci - Línea
                </NavLink>
            </div>
        }

        @if (Mostrar("/semillerolinea"))
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="semillerolinea">
                    <span class="bi bi-link-45deg-nav-menu" aria-hidden="true"></span> Semillero - Línea
                </NavLink>
            </div>
        }
             @if (Mostrar("/odslinea"))
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="odslinea">
                    <span class="bi bi-link-45deg-nav-menu" aria-hidden="true"></span> ODS - Línea
                </NavLink>
            </div>
        }
         @if (Mostrar("/ruta"))
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="ruta">
                    <span class="bi bi-permisos-nav-menu" aria-hidden="true"></span> Ruta
                </NavLink>
            </div>
        }

      
 @if (Mostrar("/rol"))
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="rol">
                    <span class="bi bi-roles-nav-menu" aria-hidden="true"></span> Rol
                </NavLink>
            </div>
        }
     

        @if (Mostrar("/usuario"))
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="usuario">
                    <span class="bi bi-usuarios-nav-menu" aria-hidden="true"></span> Usuarios
                </NavLink>
            </div>
        }

    </nav>
</div>

@code {
    private bool Mostrar(string ruta)
    {
        return _auth.EstaAutenticado && _auth.TieneAcceso(ruta);
    }
}