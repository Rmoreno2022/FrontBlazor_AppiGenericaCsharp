@page "/semillero"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Semillero</PageTitle>

<div class="container mt-4">
    <h3>Semillero</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo Semillero</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Semillero" : "Nuevo Semillero")</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Id</label>
                        <input type="number" class="form-control" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="campoNombre" maxlength="60" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Fecha Fundación</label>
                        <input type="date" class="form-control" @bind="campoFechaFundacion" />
                    </div>
                    <div class="col-md-5 mb-3">
                        <label class="form-label">Grupo de Investigación</label>
                        @if (cargandoGrupos)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                <span class="text-muted small">Cargando grupos...</span>
                            </div>
                        }
                        else
                        {
                            <select class="form-select" @bind="campoGrupoInvestigacion">
                                <option value="0">-- Seleccione un grupo --</option>
                                @foreach (var g in grupos)
                                {
                                    <option value="@g["id"]?.ToString()">@g["nombre"]?.ToString()</option>
                                }
                            </select>
                        }
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Cargando...</span></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Id</th><th>Nombre</th><th>Fecha Fundación</th><th>Grupo de Investigación</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]?.ToString()</td>
                        <td>@reg["nombre"]?.ToString()</td>
                        <td>@reg["fecha_fundacion"]?.ToString()</td>
                        <td>@(grupos.FirstOrDefault(g => g["id"]?.ToString() == reg["grupo_investigacion"]?.ToString())?["nombre"]?.ToString() ?? reg["grupo_investigacion"]?.ToString())</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> grupos = new();
    private bool cargando = true;
    private bool cargandoGrupos = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;
    private int campoId = 0;
    private string campoNombre = string.Empty;
    private DateTime? campoFechaFundacion;
    private int campoGrupoInvestigacion = 0;

    protected override async Task OnInitializedAsync()
        => await Task.WhenAll(CargarRegistros(), CargarGrupos());

    private async Task CargarRegistros()
    {
        cargando = true;
        try { registros = await Api.ListarAsync("semillero"); }
        catch (Exception ex) { mensaje = ex.Message; exito = false; registros = new(); }
        cargando = false;
    }

    private async Task CargarGrupos()
    {
        cargandoGrupos = true;
        try { grupos = await Api.ListarAsync("grupo_investigacion"); }
        catch { grupos = new(); }
        cargandoGrupos = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoId = 0; campoNombre = string.Empty;
        campoFechaFundacion = null; campoGrupoInvestigacion = 0;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = int.TryParse(reg["id"]?.ToString(), out var id) ? id : 0;
        campoNombre = reg["nombre"]?.ToString() ?? "";
        campoFechaFundacion = DateTime.TryParse(reg["fecha_fundacion"]?.ToString(), out var f) ? f : DateTime.Now;
        campoGrupoInvestigacion = int.TryParse(reg["grupo_investigacion"]?.ToString(), out var g) ? g : 0;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        if (campoId <= 0) { mensaje = "El ID es obligatorio y debe ser mayor a 0"; exito = false; return; }
        if (string.IsNullOrWhiteSpace(campoNombre)) { mensaje = "El nombre es obligatorio"; exito = false; return; }
        if (campoGrupoInvestigacion <= 0) { mensaje = "Debe seleccionar un grupo de investigación"; exito = false; return; }

        var datos = new Dictionary<string, object?>
        {
            ["id"] = campoId,
            ["nombre"] = campoNombre,
            ["fecha_fundacion"] = campoFechaFundacion?.ToString("yyyy-MM-dd"),
            ["grupo_investigacion"] = campoGrupoInvestigacion
        };

        if (editando)
        {
            datos.Remove("id");
            var r = await Api.ActualizarAsync("semillero", "id", campoId.ToString(), datos);
            exito = r.exito; mensaje = r.mensaje;
        }
        else
        {
            var r = await Api.CrearAsync("semillero", datos);
            exito = r.exito; mensaje = r.mensaje;
        }

        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string codigo = reg["id"]?.ToString() ?? "";
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar semillero con Id {codigo}?")) return;
        var r = await Api.EliminarAsync("semillero", "id", codigo);
        exito = r.exito; mensaje = r.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }
}
