@page "/participasemillero"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Participa en Semillero</PageTitle>

<div class="container mt-4">
    <h3>Participa en Semillero</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Participación</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar Participación" : "Nueva Participación")</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Cédula Docente</label>
                        <input type="number" class="form-control" @bind="campoDocente" disabled="@editando" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Semillero</label>
                        @if (cargandoSemilleros)
                        {
                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        }
                        else
                        {
                            <select class="form-select" @bind="campoSemillero" disabled="@editando">
                                <option value="0">-- Seleccione un semillero --</option>
                                @foreach (var s in semilleros)
                                {
                                    <option value="@s["id"]?.ToString()">@s["nombre"]?.ToString()</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Rol</label>
                        <input class="form-control" @bind="campoRol" maxlength="15" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Inicio</label>
                        <input type="date" class="form-control" @bind="campoFechaInicio" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Fecha Fin</label>
                        <input type="date" class="form-control" @bind="campoFechaFin" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Cargando...</span></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>Cédula Docente</th><th>Semillero</th><th>Rol</th><th>Fecha Inicio</th><th>Fecha Fin</th><th>Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["docente"]?.ToString()</td>
                        <td>@(semilleros.FirstOrDefault(s => s["id"]?.ToString() == reg["semillero"]?.ToString())?["nombre"]?.ToString() ?? reg["semillero"]?.ToString())</td>
                        <td>@reg["rol"]?.ToString()</td>
                        <td>@reg["fecha_inicio"]?.ToString()</td>
                        <td>@reg["fecha_fin"]?.ToString()</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private List<Dictionary<string, object?>> semilleros = new();
    private bool cargando = true;
    private bool cargandoSemilleros = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;
    private long campoDocente = 0;
    private int campoSemillero = 0;
    private string campoRol = string.Empty;
    private DateTime? campoFechaInicio;
    private DateTime? campoFechaFin;

    protected override async Task OnInitializedAsync()
        => await Task.WhenAll(CargarRegistros(), CargarSemilleros());

    private async Task CargarRegistros()
    {
        cargando = true;
        try { registros = await Api.ListarAsync("participa_semillero"); }
        catch (Exception ex) { mensaje = ex.Message; exito = false; registros = new(); }
        cargando = false;
    }

    private async Task CargarSemilleros()
    {
        cargandoSemilleros = true;
        try { semilleros = await Api.ListarAsync("semillero"); }
        catch { semilleros = new(); }
        cargandoSemilleros = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoDocente = 0; campoSemillero = 0; campoRol = string.Empty;
        campoFechaInicio = null; campoFechaFin = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoDocente = long.TryParse(reg["docente"]?.ToString(), out var d) ? d : 0;
        campoSemillero = int.TryParse(reg["semillero"]?.ToString(), out var s) ? s : 0;
        campoRol = reg["rol"]?.ToString() ?? "";
        campoFechaInicio = DateTime.TryParse(reg["fecha_inicio"]?.ToString(), out var fi) ? fi : null;
        campoFechaFin = DateTime.TryParse(reg["fecha_fin"]?.ToString(), out var ff) ? ff : null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        if (campoDocente <= 0) { mensaje = "La cédula del docente es obligatoria"; exito = false; return; }
        if (campoSemillero <= 0) { mensaje = "Debe seleccionar un semillero"; exito = false; return; }
        if (string.IsNullOrWhiteSpace(campoRol)) { mensaje = "El rol es obligatorio"; exito = false; return; }

        var datos = new Dictionary<string, object?>
        {
            ["docente"] = campoDocente,
            ["semillero"] = campoSemillero,
            ["rol"] = campoRol,
            ["fecha_inicio"] = campoFechaInicio?.ToString("yyyy-MM-dd"),
            ["fecha_fin"] = campoFechaFin?.ToString("yyyy-MM-dd")
        };

        if (editando)
        {
            var r = await Api.ActualizarAsync("participa_semillero", "docente", campoDocente.ToString(), datos);
            exito = r.exito; mensaje = r.mensaje;
        }
        else
        {
            var r = await Api.CrearAsync("participa_semillero", datos);
            exito = r.exito; mensaje = r.mensaje;
        }

        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string cedula = reg["docente"]?.ToString() ?? "";
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar participación del docente {cedula}?")) return;
        var r = await Api.EliminarAsync("participa_semillero", "docente", cedula);
        exito = r.exito; mensaje = r.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }
}
