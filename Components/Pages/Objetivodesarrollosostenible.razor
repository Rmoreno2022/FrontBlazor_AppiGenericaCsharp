@page "/objetivodesarrollosostenible"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject IJSRuntime JS

<PageTitle>Objetivo de Desarrollo Sostenible</PageTitle>

<div class="container mt-4">
    <h3>Objetivo de Desarrollo Sostenible</h3>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nuevo ODS</button>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">@(editando ? "Editar ODS" : "Nuevo ODS")</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Id</label>
                        <input type="number" class="form-control" @bind="campoId" disabled="@editando" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Nombre</label>
                        <input class="form-control" @bind="campoNombre" maxlength="60" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Categoría</label>
                        <input class="form-control" @bind="campoCategoria" maxlength="45" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Cargando...</span></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Id</th><th>Nombre</th><th>Categoría</th><th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]?.ToString()</td>
                        <td>@reg["nombre"]?.ToString()</td>
                        <td>@reg["categoria"]?.ToString()</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;
    private int campoId = 0;
    private string campoNombre = string.Empty;
    private string campoCategoria = string.Empty;

    protected override async Task OnInitializedAsync() => await CargarRegistros();

    private async Task CargarRegistros()
    {
        cargando = true;
        try { registros = await Api.ListarAsync("objetivo_desarrollo_sostenible"); }
        catch (Exception ex) { mensaje = ex.Message; exito = false; registros = new(); }
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoId = 0; campoNombre = string.Empty; campoCategoria = string.Empty;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = int.TryParse(reg["id"]?.ToString(), out var id) ? id : 0;
        campoNombre = reg["nombre"]?.ToString() ?? "";
        campoCategoria = reg["categoria"]?.ToString() ?? "";
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        if (campoId <= 0) { mensaje = "El ID es obligatorio y debe ser mayor a 0"; exito = false; return; }
        if (string.IsNullOrWhiteSpace(campoNombre)) { mensaje = "El nombre es obligatorio"; exito = false; return; }

        var datos = new Dictionary<string, object?> { ["id"] = campoId, ["nombre"] = campoNombre, ["categoria"] = campoCategoria };

        if (editando)
        {
            datos.Remove("id");
            var r = await Api.ActualizarAsync("objetivo_desarrollo_sostenible", "id", campoId.ToString(), datos);
            exito = r.exito; mensaje = r.mensaje;
        }
        else
        {
            var r = await Api.CrearAsync("objetivo_desarrollo_sostenible", datos);
            exito = r.exito; mensaje = r.mensaje;
        }

        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string codigo = reg["id"]?.ToString() ?? "";
        if (!await JS.InvokeAsync<bool>("confirm", $"¿Eliminar ODS con Id {codigo}?")) return;
        var r = await Api.EliminarAsync("objetivo_desarrollo_sostenible", "id", codigo);
        exito = r.exito; mensaje = r.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }
}
